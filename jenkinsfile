pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                echo 'Fetching project code...'
            }
        }

        stage('Build Docker Image') {
            steps {
                bat 'docker build -t smartapp:latest ./app'
            }
        }

        stage('Stop Old Container') {
            steps {
                bat 'docker stop smartcontainer || exit 0'
                bat 'docker rm smartcontainer || exit 0'
            }
        }

        stage('Deploy New Container') {
            steps {
                bat 'docker run -d -p 8081:80 --name smartcontainer smartapp:latest'
            }
        }

        stage('Success') {
            steps {
                echo 'Deployment Success'
            }
        }
    }
}
